  <data key="d0">Portfolio Vault RAG</data>
  <data key="d1">method</data>
  <data key="d2">Portfolio Vault RAG is a FastAPI backend that transforms markdown vault documents into a searchable, conversational knowledge base using vector embeddings and a large language model (LLM).</data>
  <data key="d3">chunk-69b74b852f9cabc07d214d1a2ef1a1b7</data>
  <data key="d4">49b9b405-a2df-4704-a521-79269f380e63</data>
  <data key="d5">1773847795</data>
  <data key="d6"></data>
</node>
