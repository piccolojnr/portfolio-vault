</node>
<node id="Qdrant Local">
  <data key="d0">Qdrant Local</data>
  <data key="d1">data</data>
  <data key="d2">Qdrant local refers to the local file storage path used in the system mentioned as "rag/data/qdrant_local/".</data>
  <data key="d3">chunk-d8787c2876f2fa9c466edf1494e57b95</data>
  <data key="d4">49b9b405-a2df-4704-a521-79269f380e63</data>
