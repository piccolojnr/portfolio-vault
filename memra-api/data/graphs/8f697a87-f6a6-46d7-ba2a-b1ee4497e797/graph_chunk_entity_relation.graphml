  <data key="d0">FastAPI</data>
  <data key="d1">technology</data>
  <data key="d2">FastAPI is the web framework used in the API layer of the Portfolio Vault RAG application.</data>
  <data key="d3">chunk-69b74b852f9cabc07d214d1a2ef1a1b7</data>
  <data key="d4">49b9b405-a2df-4704-a521-79269f380e63</data>
  <data key="d5">1773847798</data>
  <data key="d6"></data>
</node>
