<graph edgedefault="undirected"><node id="Qdrant Client">
  <data key="d0">Qdrant Client</data>
  <data key="d1">artifact</data>
  <data key="d2">Qdrant Client is a Python client for connecting to Qdrant, a vector similarity search engine.</data>
  <data key="d3">chunk-0b9224c433c7a1dffba033eb8ed5c941</data>
  <data key="d4">82ac66a6-7ad1-4828-936f-0374dc2f36fc</data>
