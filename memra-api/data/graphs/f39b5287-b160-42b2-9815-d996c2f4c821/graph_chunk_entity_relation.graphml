  <data key="d5">1773863767</data>
  <data key="d6"></data>
</node>
<node id="Encryption Key">
  <data key="d0">Encryption Key</data>
  <data key="d1">data</data>
  <data key="d2">Encryption Key refers to the secret key utilized for encrypting API keys in the database.</data>
  <data key="d3">chunk-69b74b852f9cabc07d214d1a2ef1a1b7</data>
  <data key="d4">b603e4fb-1b99-49a2-b06a-0160ff173be3</data>
  <data key="d5">1773863767</data>
  <data key="d6"></data>
</node>
<node id="Python">
  <data key="d0">Python</data>
  <data key="d1">technology</data>
  <data key="d2">Python is a programming language used to build the server infrastructure for Portfolio Vault RAG.</data>
  <data key="d3">chunk-69b74b852f9cabc07d214d1a2ef1a1b7</data>
  <data key="d4">b603e4fb-1b99-49a2-b06a-0160ff173be3</data>
  <data key="d5">1773863768</data>
  <data key="d6"></data>
</node>
<node id="Vector Embeddings">
  <data key="d0">Vector Embeddings</data>
  <data key="d1">technology</data>
  <data key="d2">Vector embeddings are used to convert markdown vault documents into a format suitable for semantic search within Portfolio Vault RAG.</data>
  <data key="d3">chunk-69b74b852f9cabc07d214d1a2ef1a1b7</data>
  <data key="d4">b603e4fb-1b99-49a2-b06a-0160ff173be3</data>
  <data key="d5">1773863771</data>
  <data key="d6"></data>
</node>
<node id="Fernet Symmetric Encryption">
  <data key="d0">Fernet Symmetric Encryption</data>
  <data key="d1">technology</data>
  <data key="d2">Fernet symmetric encryption is a method used in the Portfolio Vault RAG to ensure the security of API keys by encrypting them.</data>
  <data key="d3">chunk-69b74b852f9cabc07d214d1a2ef1a1b7</data>
  <data key="d4">b603e4fb-1b99-49a2-b06a-0160ff173be3</data>
  <data key="d5">1773863773</data>
  <data key="d6"></data>
</node>
<node id="Environment Variables">
  <data key="d0">Environment Variables</data>
  <data key="d1">concept</data>
  <data key="d2">Environment variables store important configuration details like API keys and database URLs necessary for the setup of Portfolio Vault RAG.</data>
  <data key="d3">chunk-69b74b852f9cabc07d214d1a2ef1a1b7</data>
  <data key="d4">b603e4fb-1b99-49a2-b06a-0160ff173be3</data>
  <data key="d5">1773863773</data>
  <data key="d6"></data>
</node>
<node id="Data Encryption">
  <data key="d0">Data Encryption</data>
  <data key="d1">concept</data>
  <data key="d2">Data encryption in Portfolio Vault RAG secures API keys using methods like Fernet, enhancing data protection.</data>
  <data key="d3">chunk-69b74b852f9cabc07d214d1a2ef1a1b7</data>
  <data key="d4">b603e4fb-1b99-49a2-b06a-0160ff173be3</data>
  <data key="d5">1773863775</data>
  <data key="d6"></data>
</node>
<node id="Query Logs">
  <data key="d0">Query Logs</data>
  <data key="d1">content</data>
  <data key="d2">Query Logs store cost tracking data per query.&lt;SEP&gt;Query logs are stored historical records of queries processed within the Portfolio Vault RAG system.</data>
  <data key="d3">chunk-69b74b852f9cabc07d214d1a2ef1a1b7&lt;SEP&gt;chunk-9b2357e61536898e16b9f8b1b5949ab3</data>
  <data key="d4">b603e4fb-1b99-49a2-b06a-0160ff173be3</data>
  <data key="d5">1773863775</data>
  <data key="d6"></data>
</node>
