</node>
<node id="Pydantic Schemas">
  <data key="d0">Pydantic Schemas</data>
  <data key="d1">content</data>
  <data key="d2">Pydantic Schemas provide the request/response schemas used in APIs and consist of models like QueryRequest, RetrieveResponse, and others.</data>
  <data key="d3">chunk-69b74b852f9cabc07d214d1a2ef1a1b7</data>
  <data key="d4">b603e4fb-1b99-49a2-b06a-0160ff173be3</data>
  <data key="d5">1773863757</data>
  <data key="d6"></data>
</node>
<node id="Docker">
  <data key="d0">Docker</data>
  <data key="d1">technology</data>
  <data key="d2">Docker is a container platform used commonly for deploying applications, mentioned indirectly for local storage under 'rag/data/qdrant_local/' contextually.</data>
  <data key="d3">chunk-69b74b852f9cabc07d214d1a2ef1a1b7</data>
  <data key="d4">b603e4fb-1b99-49a2-b06a-0160ff173be3</data>
  <data key="d5">1773863758</data>
  <data key="d6"></data>
</node>
