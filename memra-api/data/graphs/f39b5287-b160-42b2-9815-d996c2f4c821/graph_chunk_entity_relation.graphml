  <data key="d6"></data>
</node>
<node id="Pipeline Run">
  <data key="d0">Pipeline Run</data>
  <data key="d1">method</data>
  <data key="d2">The Pipeline Run involves executing index_all_docs() in a thread pool executor and bridging events into an async generator via queue.Queue.</data>
  <data key="d3">chunk-9b2357e61536898e16b9f8b1b5949ab3</data>
  <data key="d4">b603e4fb-1b99-49a2-b06a-0160ff173be3</data>
