  <data key="d0">Api Endpoints</data>
  <data key="d1">content</data>
  <data key="d2">API Endpoints refer to the structured paths and methods provided to interact with the application.</data>
  <data key="d3">chunk-d8787c2876f2fa9c466edf1494e57b95</data>
  <data key="d4">b603e4fb-1b99-49a2-b06a-0160ff173be3</data>
  <data key="d5">1773863784</data>
  <data key="d6"></data>
</node>
