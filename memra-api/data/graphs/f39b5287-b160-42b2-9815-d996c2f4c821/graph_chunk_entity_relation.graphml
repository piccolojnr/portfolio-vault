  <data key="d0">Qdrant URL</data>
  <data key="d1">data</data>
  <data key="d2">Qdrant URL is the configuration setting for connecting to Qdrant for storage and retrieval in Portfolio Vault RAG.</data>
  <data key="d3">chunk-69b74b852f9cabc07d214d1a2ef1a1b7</data>
  <data key="d4">b603e4fb-1b99-49a2-b06a-0160ff173be3</data>
  <data key="d5">1773863765</data>
