  <data key="d1">data</data>
  <data key="d2">OpenAI API Key is required for embedding processes in Portfolio Vault RAG and is kept in the `.env` configuration.</data>
  <data key="d3">chunk-69b74b852f9cabc07d214d1a2ef1a1b7</data>
  <data key="d4">b603e4fb-1b99-49a2-b06a-0160ff173be3</data>
  <data key="d5">1773863759</data>
  <data key="d6"></data>
</node>
<node id="Anthropic API Key">
  <data key="d0">Anthropic API Key</data>
  <data key="d1">data</data>
  <data key="d2">Anthropic API Key is an optional API key for LLM answers in Portfolio Vault RAG, stored in the `.env` file.</data>
  <data key="d3">chunk-69b74b852f9cabc07d214d1a2ef1a1b7</data>
  <data key="d4">b603e4fb-1b99-49a2-b06a-0160ff173be3</data>
