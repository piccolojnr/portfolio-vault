</node>
<node id="Python Server">
  <data key="d0">Python Server</data>
  <data key="d1">technology</data>
  <data key="d2">Python Server represents the main technology infrastructure on which the Portfolio Vault RAG runs.</data>
  <data key="d3">chunk-69b74b852f9cabc07d214d1a2ef1a1b7</data>
  <data key="d4">b603e4fb-1b99-49a2-b06a-0160ff173be3</data>
