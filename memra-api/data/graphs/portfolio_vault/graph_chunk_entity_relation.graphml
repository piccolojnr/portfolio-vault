  <data key="d13"></data>
</edge>
<edge source="LightRAG" target="Qdrant">
  <data key="d7">1.0</data>
  <data key="d8">LightRAG works with Qdrant to perform focused queries with an adjustable top_k parameter.</data>
  <data key="d9">query processing,results retrieval</data>
  <data key="d10">chunk-b4aa97eb500d161464a14c94ae6047c2</data>
  <data key="d11">d3ff01e3-398a-4879-916a-a7085be7b28d</data>
  <data key="d12">1773846973</data>
  <data key="d13"></data>
</edge>
<edge source="Health-Check Warm-Up" target="FastAPI">
  <data key="d7">1.0</data>
  <data key="d8">FastAPI can include a Health-Check Warm-Up strategy to ensure services are ready before requests.</data>
  <data key="d9">readiness strategy,server management</data>
  <data key="d10">chunk-b4aa97eb500d161464a14c94ae6047c2</data>
  <data key="d11">d3ff01e3-398a-4879-916a-a7085be7b28d</data>
