  <data key="d13"></data>
</edge>
<edge source="History Fetch" target="Message Persist">
  <data key="d7">1.0</data>
  <data key="d8">The connection is maintained during both the History Fetch and Message Persist methods, within a 50–200 ms timeframe.</data>
