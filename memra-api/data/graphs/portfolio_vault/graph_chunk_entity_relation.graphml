  <data key="d10">chunk-dcd6b1fd8f26bb84cb9d480ce1372752</data>
  <data key="d11">d3ff01e3-398a-4879-916a-a7085be7b28d</data>
  <data key="d12">1773846975</data>
  <data key="d13"></data>
</edge>
<edge source="P95 Latency" target="Pool Size">
  <data key="d7">1.0</data>
  <data key="d8">If P95 Latency increases under load, raising the Pool Size to 10 is recommended to manage it.</data>
  <data key="d9">configuration,latency management</data>
  <data key="d10">chunk-dcd6b1fd8f26bb84cb9d480ce1372752</data>
