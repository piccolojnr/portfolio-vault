# ── Required for production ────────────────────────────────────────────────────

# PostgreSQL connection string.
# On Vercel, use a connection pooler URL (Supabase "Transaction" mode,
# Neon pooled endpoint, etc.) to avoid exhausting DB connections across
# parallel serverless instances.
DATABASE_URL=postgresql://user:password@host:5432/portfolio_vault

# Qdrant Cloud — local file storage is not available on serverless.
# Create a free cluster at cloud.qdrant.io.
QDRANT_URL=https://<cluster-id>.us-east4-0.gcp.cloud.qdrant.io
QDRANT_API_KEY=
# Vector provider for memra.infrastructure.vector:
# - qdrant (default, production recommended)
# - nano    (local LightRAG vector DB for dev; infrastructure.vector remains qdrant-only)
# - chroma  (compat alias to nano in LightRAG paths)
VECTOR_PROVIDER=qdrant

# Secret key for encrypting API keys stored in the settings DB table.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# Keep stable — changing it invalidates all stored encrypted keys.
SECRET_KEY=

# ── Optional — can also be set via the /settings UI at runtime ─────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Neo4j (graph storage) ─────────────────────────────────────────────────────
# Neo4j Aura free tier: 50k nodes, 175k relationships, no time limit.
# Used by LightRAG as the graph backend (replaces NetworkXStorage).
NEO4J_URI=neo4j+s://xxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

# ── Deployment ────────────────────────────────────────────────────────────────
ENVIRONMENT=development                # development | production
GUNICORN_WORKERS=4                     # Number of Gunicorn workers (production only)
CORS_ORIGINS=                          # Comma-separated allowed origins (empty = allow all)

# ── Local dev only ─────────────────────────────────────────────────────────────
# DEMO_MODE=1  # run without any API keys (returns mock responses)
# LOG_LEVEL=DEBUG  # memra.* loggers (extra Paystack webhook detail stays at DEBUG)
# LOCAL_DEV_EPHEMERAL=1  # store local uploads/chunks/vectors in OS temp

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=                        # Required for auth; 32+ random chars
JWT_ACCESS_EXPIRY_MINUTES=15       # Access token lifetime (minutes)
JWT_REFRESH_EXPIRY_DAYS=30         # Refresh token lifetime (days)

# ── Platform Admin ───────────────────────────────────────────────────────────
ADMIN_JWT_SECRET=                  # Separate JWT secret for admin tokens (falls back to JWT_SECRET)
ADMIN_JWT_REFRESH_EXPIRY_DAYS=7    # Admin refresh token lifetime (shorter than user tokens)

# ── Email ──────────────────────────────────────────────────────────────────────
EMAIL_BACKEND=console              # console | mailpit | resend
EMAIL_FROM=noreply@example.com     # Sender address used in all outbound email
RESEND_API_KEY=                    # Required when EMAIL_BACKEND=resend
MAILPIT_HOST=localhost              # SMTP host for Mailpit (local dev)
MAILPIT_PORT=1025                  # SMTP port for Mailpit

# ── App metadata (used in email templates) ────────────────────────────────────
APP_NAME=Memraiq
APP_URL=http://app.memra.local

# ── Billing / Paystack (documented) ───────────────────────────────────────────
# NOTE: these are NOT read from .env at runtime in the current architecture.
# They are stored in the `platform_settings` table and managed from
# Platform Admin Settings UI/API:
#   - paystack_secret_key        (secret)
#   - paystack_public_key
#   - paystack_pro_plan_code
#   - paystack_enterprise_plan_code
#
# Keep this section as documentation so deployment setup is explicit.
